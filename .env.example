# ============================================================
# Nur Trading Bot — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ── Telegram ─────────────────────────────────────────────────
TELEGRAM_TOKEN=your_bot_token_here
# Comma-separated chat IDs allowed to control the bot
# Get your chat_id by messaging @userinfobot on Telegram
ALLOWED_CHAT_IDS=123456789

# ── Trading Mode ─────────────────────────────────────────────
# Set to true to simulate trades without real orders
PAPER_TRADING=false

# ── Risk Settings ─────────────────────────────────────────────
RISK_PERCENT=1.0
DAILY_LOSS_LIMIT=-50.0
DAILY_PROFIT_TARGET=100.0
MAX_TRADES_PER_DAY=5
MIN_SCORE_TO_TRADE=70

# ── Strategy ─────────────────────────────────────────────────
SYMBOL=XAUUSD
EMA_PERIOD=200
ATR_PERIOD=14
COOLDOWN_SECONDS=30

# ── Conversational AI ──────────────────────────────────────────
# Google Gemini API Key from Google AI Studio (Free)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Google OAuth Setup ────────────────────────────────────────
# HOW TO GET THESE VALUES:
# 1. Go to: https://console.cloud.google.com
# 2. Create project "Nur Trading Bot"
# 3. APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 4. Application type: Web application
# 5. Authorized redirect URIs: http://localhost:8000/api/auth/google/callback
# 6. Copy Client ID and Client Secret below
#
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
VITE_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ── JWT Secret (change this to any random string) ────────────
JWT_SECRET=nur-jwt-secret-change-this-to-something-random
